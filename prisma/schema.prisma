datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["mundial"]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

model Usuario {
  id                     Int                  @id @default(autoincrement())
  nombre                 String               @db.VarChar(100)
  username               String               @unique @db.VarChar(100)
  passwordHash           String               @map("password_hash") @db.VarChar(255)
  rol                    String               @default("user") @db.VarChar(20)
  puntosTotales          Int                  @default(0) @map("puntos_totales")
  createdAt              DateTime             @default(now()) @map("created_at")
  pronosticosPartidos    PronosticoPartido[]
  prediccionesEspeciales PrediccionEspecial[]

  @@map("usuarios")
  @@schema("mundial")
}

model Pais {
  id                 Int                  @id @default(autoincrement())
  nombre             String               @unique @db.VarChar(50)
  banderaUrl         String?              @map("bandera_url") @db.VarChar(500)
  jugadores          Jugador[]
  grupos             Grupo[]
  tarjetas           TarjetaPartido[]
  partidosLocal      Partido[]            @relation("Local")
  partidosVisitante  Partido[]            @relation("Visitante")
  especialesCampeon  PrediccionEspecial[] @relation("Campeon")
  especialesSorpresa PrediccionEspecial[] @relation("Sorpresa")

  @@map("paises")
  @@schema("mundial")
}

model Jugador {
  id                  Int                  @id @default(autoincrement())
  paisId              Int                  @map("pais_id")
  nombre              String               @db.VarChar(100)
  posicion            String?              @db.VarChar(50)
  dorsal              Int?
  edad                Int?
  fotoUrl             String?              @map("foto_url") @db.VarChar(500)
  pais                Pais                 @relation(fields: [paisId], references: [id], onDelete: Cascade)
  goles               GolPartido[]
  especialesBalonOro  PrediccionEspecial[] @relation("BalonOro")
  especialesBotaOro   PrediccionEspecial[] @relation("BotaOro")
  especialesGuanteOro PrediccionEspecial[] @relation("GuanteOro")

  @@map("jugadores")
  @@schema("mundial")
}

model Grupo {
  id              Int    @id @default(autoincrement())
  nombre          String @db.VarChar(5) // A, B, C, ... L
  paisId          Int    @map("pais_id")
  puntos          Int    @default(0)
  partidosJugados Int    @default(0) @map("partidos_jugados")
  ganados         Int    @default(0)
  empatados       Int    @default(0)
  perdidos        Int    @default(0)
  golesAFavor     Int    @default(0) @map("goles_a_favor")
  golesEnContra   Int    @default(0) @map("goles_en_contra")
  diferenciaGoles Int    @default(0) @map("diferencia_goles")
  tarjetasAmarillas Int  @default(0) @map("tarjetas_amarillas")
  tarjetasRojas   Int    @default(0) @map("tarjetas_rojas")
  fairPlayPuntos  Int    @default(0) @map("fair_play_puntos")
  pais            Pais   @relation(fields: [paisId], references: [id])

  @@unique([nombre, paisId])
  @@map("grupos")
  @@schema("mundial")
}

model GolPartido {
  id        Int    @id @default(autoincrement())
  partidoId Int    @map("partido_id")
  jugadorId Int    @map("jugador_id")
  minuto    Int?
  tipo      String @default("normal") @db.VarChar(30) // normal, penal, autogol
  partido   Partido  @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  jugador   Jugador  @relation(fields: [jugadorId], references: [id], onDelete: Cascade)

  @@map("goles_partidos")
  @@schema("mundial")
}

model TarjetaPartido {
  id        Int    @id @default(autoincrement())
  partidoId Int    @map("partido_id")
  paisId    Int    @map("pais_id")
  tipo      String @db.VarChar(10) // amarilla, roja
  minuto    Int?
  partido   Partido @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  pais      Pais    @relation(fields: [paisId], references: [id], onDelete: Cascade)

  @@map("tarjetas_partidos")
  @@schema("mundial")
}

model Partido {
  id                  Int                 @id @default(autoincrement())
  localId             Int                 @map("local_id")
  visitanteId         Int                 @map("visitante_id")
  fase                String              @db.VarChar(50)
  grupo               String?             @db.VarChar(5)
  fecha               DateTime
  golesLocal          Int?                @map("goles_local")
  golesVisitante      Int?                @map("goles_visitante")
  estado              String              @default("programado") @db.VarChar(20) // programado | en_vivo | finalizado
  bloqueado           Boolean             @default(false)
  actualizadoPorAdmin Boolean             @default(false) @map("actualizado_por_admin")
  local               Pais                @relation("Local", fields: [localId], references: [id])
  visitante           Pais                @relation("Visitante", fields: [visitanteId], references: [id])
  pronosticos         PronosticoPartido[]
  goles               GolPartido[]
  tarjetas            TarjetaPartido[]

  @@map("partidos")
  @@schema("mundial")
}

model PronosticoPartido {
  id                  Int      @id @default(autoincrement())
  usuarioId           Int      @map("usuario_id")
  partidoId           Int      @map("partido_id")
  prediccionLocal     Int      @map("prediccion_local")
  prediccionVisitante Int      @map("prediccion_visitante")
  puntosGanados       Int      @default(0) @map("puntos_ganados")
  createdAt           DateTime @default(now()) @map("created_at")
  usuario             Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  partido             Partido  @relation(fields: [partidoId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, partidoId])
  @@map("pronosticos_partidos")
  @@schema("mundial")
}

model PrediccionEspecial {
  id             Int      @id @default(autoincrement())
  usuarioId      Int      @map("usuario_id")
  campeonId      Int?     @map("campeon_id")
  sorpresaId     Int?     @map("sorpresa_id")
  balonOroId     Int?     @map("balon_oro_id")
  botaOroId      Int?     @map("bota_oro_id")
  guanteOroId    Int?     @map("guante_oro_id")
  bloqueado      Boolean  @default(false)
  puntosCampeon  Int      @default(0) @map("puntos_campeon")
  puntosSorpresa Int      @default(0) @map("puntos_sorpresa")
  puntosBalon    Int      @default(0) @map("puntos_balon")
  puntosBota     Int      @default(0) @map("puntos_bota")
  puntosGuante   Int      @default(0) @map("puntos_guante")
  usuario        Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  campeon        Pais?    @relation("Campeon", fields: [campeonId], references: [id])
  sorpresa       Pais?    @relation("Sorpresa", fields: [sorpresaId], references: [id])
  balonOro       Jugador? @relation("BalonOro", fields: [balonOroId], references: [id])
  botaOro        Jugador? @relation("BotaOro", fields: [botaOroId], references: [id])
  guanteOro      Jugador? @relation("GuanteOro", fields: [guanteOroId], references: [id])

  @@map("predicciones_especiales")
  @@schema("mundial")
}
