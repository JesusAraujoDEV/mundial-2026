# ═══════════════════════════════════════════════════════════════
# MUNDIAL 2026 - QUINIELA API
# Variables de entorno para producción (Dokploy)
# ═══════════════════════════════════════════════════════════════

# Puerto donde corre la aplicación NestJS
PORT=3000

# URL de conexión a PostgreSQL
# IMPORTANTE: El parámetro ?schema=mundial es obligatorio para que
# Prisma apunte al esquema correcto dentro de la base de datos.
DATABASE_URL="postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB?schema=mundial"

# Entorno de ejecución
NODE_ENV=production

# ───────────────────────────────────────────────────────────────
# Evolution API (notificaciones de WhatsApp)
# ───────────────────────────────────────────────────────────────
EVOLUTION_API_BASE_URL=https://tu-evolution-api.com
EVOLUTION_INSTANCE=NombreInstancia
EVOLUTION_API_KEY=tu-api-key
# ID del grupo de WhatsApp destino (recordatorios y avisos de gol)
EVOLUTION_GROUP_ID=000000000000000000

# ───────────────────────────────────────────────────────────────
# Recordatorios de partidos
# ───────────────────────────────────────────────────────────────
# Activa/desactiva el envío automático de recordatorios
RECORDATORIOS_ENABLED=true
# Minutos de anticipación con que se avisa antes de cada partido
RECORDATORIO_ANTICIPACION_MIN=5
# Frecuencia con que el poller revisa próximos partidos (ms)
RECORDATORIO_CHECK_MS=60000
# Zona horaria para mostrar la hora del partido en los mensajes
TZ_LOCAL=America/Caracas
